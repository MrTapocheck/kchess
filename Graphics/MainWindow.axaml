<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:kchess"
        x:Class="kchess.Graphics.MainWindow"
        Title="kchess"
        Width="900" Height="700"
        WindowStartupLocation="CenterScreen"
        x:DataType="vm:MainViewModel">

    <Grid ColumnDefinitions="*,300" Margin="10">
        
        <!-- ЛЕВАЯ ЧАСТЬ: Доска -->
        <Border Grid.Column="0" Background="#333" CornerRadius="5" Padding="5">
            <Grid x:Name="ChessBoardGrid" 
                  ColumnDefinitions="*,*,*,*,*,*,*,*" 
                  RowDefinitions="*,*,*,*,*,*,*,*"/>
        </Border>

        <!-- ПРАВАЯ ЧАСТЬ: Панель управления -->
        <StackPanel Grid.Column="1" Margin="10,0,0,0" Spacing="10">
            
            <!-- Статус игры -->
            <Border Background="#444" CornerRadius="5" Padding="15">
                <TextBlock Text="{Binding StatusMessage}" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"/>
            </Border>

            <!-- Кнопки управления -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
                <Button Content="Новая игра" Click="NewGame_Click" Padding="10,5"/>
                <!-- Кнопку отмены пока закомментируем, пока не реализуем Undo в движке -->
                <!-- <Button Content="Отменить" Padding="10,5"/> -->
            </StackPanel>

            <!-- Заголовок истории -->
            <TextBlock Text="История ходов" FontSize="16" FontWeight="Bold" Margin="0,10,0,5"/>

            <!-- Список ходов -->
            <Border Background="#2a2a2a" CornerRadius="5" Padding="5">
                <ListBox ItemsSource="{Binding MoveHistoryList}" 
                         Background="Transparent"
                         BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="40,*,*" Margin="2">
                                <!-- Номер хода -->
                                <TextBlock Grid.Column="0" 
                                           Text="{Binding MoveNumber}" 
                                           FontWeight="Bold"
                                           Foreground="#aaa"/>
                                
                                <!-- Ход белых -->
                                <TextBlock Grid.Column="1" 
                                           Text="{Binding WhiteMove}" 
                                           Foreground="White"
                                           Margin="5,0"/>
                                
                                <!-- Ход черных -->
                                <TextBlock Grid.Column="2" 
                                           Text="{Binding BlackMove}" 
                                           Foreground="White"
                                           Margin="5,0"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </StackPanel>
    </Grid>
</Window>